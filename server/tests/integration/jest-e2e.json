{
  "moduleFileExtensions": ["js", "json", "ts"],
  "rootDir": "../..",
  "testEnvironment": "node",
  "testMatch": ["<rootDir>/tests/integration/**/*.e2e-spec.ts"],
  "moduleNameMapper": {
    "^uuid$": "<rootDir>/tests/integration/uuid.mock.js",
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
  "transform": {
    "^.+\\.ts$": "ts-jest"
  }
}
